# Copy to .deploy.env (gitignored) and fill all values. Then run setup-deploy-secrets.sh.

FLY_API_TOKEN=
VERCEL_TOKEN=

# Supabase connection (incl. password) — grab from dashboard:
# https://supabase.com/dashboard/project/nmxexbprvuzwyhxtfnub/settings/database
# Use the "URI" format under "Connection string". Replace driver to asyncpg:
#   postgresql://...   ->   postgresql+asyncpg://...
DATABASE_URL=

# Supabase auth secrets — dashboard /settings/api
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=sb_publishable_D-PXHamK43D4mlhrGuyf4g_W8br1OTB

# OpenAI (Vision-capable account)
OPENAI_API_KEY=

# Web (Vercel build/runtime env)
NEXT_PUBLIC_SUPABASE_URL=https://nmxexbprvuzwyhxtfnub.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_D-PXHamK43D4mlhrGuyf4g_W8br1OTB
# Set after the first backend deploy completes:
NEXT_PUBLIC_API_URL=https://handwerk-backend.fly.dev

# Backend CORS — accepts comma-separated origins. Set to your Vercel URL after first web deploy.
CORS_ORIGINS=https://handwerk-saas.vercel.app
