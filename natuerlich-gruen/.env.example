# Basis-URL der Seite (für Canonical-Tags, Sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://natuerlichgruen.net

# --- Kontaktformular / E-Mail-Versand (Resend) ---
# API-Key von https://resend.com – ohne diesen Wert werden Anfragen nur
# geloggt und der Versand übersprungen (nützlich für lokale Tests).
RESEND_API_KEY=
# Absender-Adresse (muss bei Resend verifiziert sein)
CONTACT_FROM_EMAIL=website@natuerlichgruen.net
# Empfänger der Kontaktanfragen
CONTACT_TO_EMAIL=info@natuerlichgruen.net

# --- Spam-Schutz (Cloudflare Turnstile, optional) ---
# Wenn beide Werte gesetzt sind, wird das Formular serverseitig gegen
# Turnstile validiert. Ohne diese Werte greift nur der Honeypot + Rate-Limit.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
