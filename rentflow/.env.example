# ---------------------------------------------------------------------------
# RentFlow environment variables (see prompt §13)
# Copy to .env.local for local development. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Public base URL of the app (used for redirects, Stripe return URLs, emails, SEO)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used by webhooks, the public booking route and crons.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=
# Webhook secret for the PLATFORM account (subscriptions)
STRIPE_WEBHOOK_SECRET=
# Webhook secret for CONNECT events (connected accounts / tenant payments)
STRIPE_CONNECT_WEBHOOK_SECRET=

# Platform subscription price IDs (created on the platform Stripe account)
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Optional application fee on tenant payments, in basis points. Default 0 (MVP).
PLATFORM_FEE_BPS=0

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
# Verified sender, e.g. "RentFlow <buchung@deinedomain.de>"
RESEND_FROM="RentFlow <onboarding@resend.dev>"

# --- Cron ------------------------------------------------------------------
# Shared secret required by /api/cron/* routes (sent as Authorization: Bearer <secret>)
CRON_SECRET=

# --- Analytics (optional) --------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
