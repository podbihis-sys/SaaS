# --- App ---
# Public base URL of the web app (used for links in emails, OG, canonical URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (two products: Starter, Pro — each monthly + yearly).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Verified sender, e.g. "BFSG-Monitor <noreply@ihre-domain.de>".
# Defaults to Resend's test sender if unset.
RESEND_FROM=

# --- Scan worker (separate Node/Playwright service on Railway) ---
SCAN_WORKER_URL=
# Shared secret sent as the x-worker-secret header to authenticate scan requests.
SCAN_WORKER_SECRET=

# --- Cron ---
# Shared secret required by /api/cron/* endpoints (sent by Vercel Cron).
CRON_SECRET=
