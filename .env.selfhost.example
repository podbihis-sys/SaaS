# =============================================================================
# Self-hosting environment for the BIT website + its own Supabase instance.
#
#   cp .env.selfhost.example .env.selfhost
#   ./scripts/generate-secrets.sh        # fills in the secrets below
#   docker compose -f docker-compose.selfhost.yml --env-file .env.selfhost up -d
#
# NEVER commit the real .env.selfhost – only this .example file.
# =============================================================================

# -----------------------------------------------------------------------------
# Domains & HTTPS
# -----------------------------------------------------------------------------
# Public domain of the BIT website (Next.js).
SITE_DOMAIN=bit-gmbh.de
# Public domain of the self-hosted Supabase API (Kong gateway).
API_DOMAIN=api.bit-gmbh.de
# Public domain for Supabase Studio. Leave the Caddy "studio" block in place only
# if this is set to a real host; otherwise remove that block from caddy/Caddyfile.
STUDIO_DOMAIN=studio.bit-gmbh.de
# Email for Let's Encrypt certificate registration.
ACME_EMAIL=admin@bit-gmbh.de

# Full public URLs (derived from the domains above – keep them in sync).
SITE_URL=https://bit-gmbh.de
SUPABASE_PUBLIC_URL=https://api.bit-gmbh.de
# Extra OAuth/redirect URLs allowed by GoTrue (comma separated, optional).
ADDITIONAL_REDIRECT_URLS=https://bit-gmbh.de/bit

# -----------------------------------------------------------------------------
# Secrets  (generate with ./scripts/generate-secrets.sh – DO NOT reuse examples)
# -----------------------------------------------------------------------------
# Postgres superuser / service-role password.
#   openssl rand -hex 24
POSTGRES_PASSWORD=replace-with-strong-password

# Symmetric secret used to sign all JWTs (min 32 chars).
#   openssl rand -hex 32
JWT_SECRET=replace-with-32+char-random-string

# JWTs signed with JWT_SECRET, role "anon" and "service_role" respectively.
# Generate with: ./scripts/generate-secrets.sh  (or see docs/self-hosting.md)
ANON_KEY=replace-with-anon-jwt
SERVICE_ROLE_KEY=replace-with-service-role-jwt

# Access-token lifetime in seconds (1 hour).
JWT_EXPIRY=3600

# -----------------------------------------------------------------------------
# Auth (GoTrue) behaviour
# -----------------------------------------------------------------------------
# Set to false to allow public self-service signups (BIT is admin-only -> true).
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
# true skips the e-mail confirmation step (handy without SMTP). Set false in prod
# once SMTP below is configured, so admin invites work properly.
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP for admin invites / password resets (optional but recommended in prod).
SMTP_ADMIN_EMAIL=admin@bit-gmbh.de
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=BIT GmbH

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Max upload size in bytes (50 MB).
STORAGE_FILE_SIZE_LIMIT=52428800

# -----------------------------------------------------------------------------
# Studio (admin UI) – fronted by Caddy basic auth
# -----------------------------------------------------------------------------
STUDIO_BASIC_AUTH_USER=admin
# bcrypt hash for Caddy basic auth:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
STUDIO_BASIC_AUTH_HASH=
# Plaintext dashboard password used by Kong's basic-auth consumer (Studio<->Kong).
DASHBOARD_PASSWORD=change-me
STUDIO_DEFAULT_ORGANIZATION=BIT GmbH
STUDIO_DEFAULT_PROJECT=BIT

# -----------------------------------------------------------------------------
# Next.js public env (inlined at build time)
# -----------------------------------------------------------------------------
# BIT website -> self-hosted Supabase instance.
NEXT_PUBLIC_BIT_SUPABASE_URL=https://api.bit-gmbh.de
NEXT_PUBLIC_BIT_SUPABASE_ANON_KEY=replace-with-anon-jwt

# Main SaaS app Supabase. Point at the same self-hosted instance, or keep an
# external/cloud value if the main app is hosted elsewhere.
NEXT_PUBLIC_SUPABASE_URL=https://api.bit-gmbh.de
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-jwt

NEXT_PUBLIC_SITE_URL=https://bit-gmbh.de
# Optional FastAPI backend URL (leave empty if not deployed here).
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Cloud -> self-host migration (used by scripts/, not by the running stack)
# -----------------------------------------------------------------------------
# Direct Postgres connection string of the EXISTING cloud project (bit-gmbh).
# Dashboard -> Project Settings -> Database -> Connection string (URI).
CLOUD_DB_URL=postgresql://postgres:[YOUR-CLOUD-DB-PASSWORD]@db.lhllsywxusrqtxcpnjbo.supabase.co:5432/postgres
# Cloud project API URL + service-role key (for copying storage files).
CLOUD_SUPABASE_URL=https://lhllsywxusrqtxcpnjbo.supabase.co
CLOUD_SERVICE_ROLE_KEY=replace-with-cloud-service-role-key
# Storage bucket to migrate.
BIT_STORAGE_BUCKET=bit-product-images
